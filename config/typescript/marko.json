{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Marko",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "importHelpers": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true
  }
}
