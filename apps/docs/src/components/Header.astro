---
import { SearchBar } from './SearchBar';
import { MobileActionButtons, MobileNavToggle } from './MobileHeaderActions';
import { ThemeToggle } from './ThemeToggle';

type VersionInfo = { name: string; href: string; isActive: boolean };
type NavbarLink = { label: string; href: string };
type NavbarPrimary = { type: string; label: string; href: string };
type NavbarConfig = {
  links?: NavbarLink[];
  primary?: NavbarPrimary;
  github?: string;
};

interface Props {
  pageTitle?: string;
  groupName?: string;
  versionTabs?: VersionInfo[];
  navbarConfig?: NavbarConfig;
}

const { pageTitle, groupName, versionTabs = [], navbarConfig } = Astro.props;
const activeVersion = versionTabs.find((v) => v.isActive);
const hasVersions = versionTabs.length > 1;
---

<header class="sticky top-0 w-full px-8 z-50">
  <div
    class="absolute left-1/2 -translate-x-1/2 w-screen h-full backdrop-blur flex-none transition-colors duration-500 border-b border-gray-500/5 bg-white/95 supports-backdrop-blur:bg-white/60 dark:bg-background-dark/95 dark:supports-backdrop-blur:bg-background-dark/60 dark:border-white/5"
  >
  </div>
  <div class="relative">
    <div>
      <div class="relative">
        <div class:list={['flex items-center h-16 min-w-0']}>
          <div
            class="h-full relative flex-1 flex items-center justify-between gap-x-4 min-w-0 lg:border-none"
          >
            {/* Left: logo + version */}
            <div class="flex items-center gap-3 shrink-0">
              <a href="/" class="flex items-center shrink-0" data-logo-link>
                <img src="/images/logo/logo.svg" alt="dnd kit" width="135" height="45" class="h-[45px] w-auto" />
              </a>
              {hasVersions && (
                <div class="relative hidden lg:block" data-version-dropdown>
                  <button
                    class="flex items-center gap-1 text-sm font-medium text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 px-2 py-1 rounded-md hover:bg-gray-100 dark:hover:bg-white/5 cursor-pointer"
                    data-version-toggle
                  >
                    {activeVersion?.name || 'Latest'}
                    <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </button>
                  <div
                    class="absolute top-full left-0 mt-1 w-36 bg-white dark:bg-gray-950 border border-gray-200 dark:border-white/10 rounded-lg shadow-lg py-1 hidden z-[100]"
                    data-version-menu
                  >
                    {versionTabs.map((v) => (
                      <a
                        href={v.href}
                        class:list={[
                          'block px-3 py-1.5 text-sm',
                          v.isActive
                            ? 'text-(--primary) font-medium bg-gray-50 dark:bg-white/5'
                            : 'text-gray-600 hover:text-gray-800 hover:bg-gray-50 dark:text-gray-400 dark:hover:text-gray-200 dark:hover:bg-white/5',
                        ]}
                      >
                        {v.name}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>

            {/* Center: search */}
            <div class="flex-1 hidden lg:flex items-center justify-center min-w-0">
              <div class="w-full max-w-sm">
                <SearchBar client:load />
              </div>
            </div>

            <MobileActionButtons client:load />

            {/* Right: links + icons */}
            <div class="hidden lg:flex items-center gap-4 shrink-0">
              {navbarConfig?.links?.map((link) => {
                const isExternal = link.href.startsWith('http');
                return (
                  <a
                    href={link.href}
                    target={isExternal ? '_blank' : undefined}
                    rel={isExternal ? 'noopener noreferrer' : undefined}
                    class="text-sm font-medium text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200"
                  >
                    {link.label}
                  </a>
                );
              })}
              {navbarConfig?.github && (
                <a
                  href={navbarConfig.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-1.5 rounded-md text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
                  aria-label="GitHub"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                </a>
              )}
              <ThemeToggle client:load />
            </div>
          </div>
        </div>
        {
          pageTitle && (
            <MobileNavToggle
              pageTitle={pageTitle}
              groupName={groupName}
              client:load
            />
          )
        }
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const dropdowns = document.querySelectorAll('[data-version-dropdown]');
    dropdowns.forEach((dropdown) => {
      const toggle = dropdown.querySelector('[data-version-toggle]');
      const menu = dropdown.querySelector('[data-version-menu]');
      if (!toggle || !menu) return;

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });

      document.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  });
</script>
