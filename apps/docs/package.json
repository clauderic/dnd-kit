{
  "name": "@dnd-kit/docs",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation site for @dnd-kit, powered by Astro and Mintlify.",
  "scripts": {
    "dev": "astro dev --port 3000",
    "build": "node scripts/generate-og-image.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "diff": "node scripts/diff-screenshots.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.70",
    "@astrojs/mdx": "^4.3.1",
    "@astrojs/preact": "4",
    "@astrojs/sitemap": "^3.7.2",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@mintlify/astro": "^0.1.9",
    "@mintlify/components": "^1.0.5",
    "@mintlify/models": "^0.0.260",
    "@mintlify/validation": "^0.1.574",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "ai": "^6.0.68",
    "astro": "^5.16.12",
    "preact": "^10.29.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "satori": "^0.26.0",
    "simple-icons": "^14.0.0",
    "tailwindcss": "^4.1.18",
    "use-debounce": "^10.1.0",
    "vite": "^6.4.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}
