{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "tags/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
