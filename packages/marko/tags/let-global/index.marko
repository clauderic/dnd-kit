export interface Input<T extends keyof Marko.Global> {
  from: T;
}

// No TypeScript generics in client const — angle brackets conflict with Marko's
// tag parser in this context. Runtime type is Map<PropertyKey, Set<fn>>.
client const subsMap = new Map();

<let/value=($global ?? {})[input.from]>

<script>
  const _key = input.from as PropertyKey;
  if (!subsMap.has(_key)) subsMap.set(_key, new Set());
  const _keySubs: Set<(v: unknown) => void> = subsMap.get(_key);
  const fn = (next: unknown) => { value = next as typeof value; };
  $signal.onabort = () => _keySubs.delete(fn);
  _keySubs.add(fn);
</script>

<return=value valueChange(next: unknown) {
  ($global as any)[input.from] = next;
  const _keySubs: Set<(v: unknown) => void> | undefined = subsMap.get(input.from);
  if (_keySubs) for (const sub of _keySubs) sub(next);
}/>
