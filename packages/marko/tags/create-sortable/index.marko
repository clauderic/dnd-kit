import {
  Sortable,
  defaultSortableTransition,
  OptimisticSortingPlugin,
} from "@dnd-kit/dom/sortable";
import type { SortableInput } from "@dnd-kit/dom/sortable";
import type { DragDropManager } from "@dnd-kit/dom";
import type { Data, Plugins } from "@dnd-kit/abstract";
import { batch } from "@dnd-kit/state";

export interface SortableMethods {
  isDragging: boolean;
  isDropping: boolean;
  isDragSource: boolean;
  isDropTarget: boolean;
  setElement(el: HTMLElement | undefined): void;
  setHandle(el: HTMLElement | undefined): void;
  setSource(el: HTMLElement | undefined): void;
  setTarget(el: HTMLElement | undefined): void;
}

export interface Input<T extends Data = Data> {
  id: string | number;
  index: number;
  group?: string;
  data?: T;
  disabled?: boolean;
  sensors?: SortableInput<T>["sensors"];
  modifiers?: SortableInput<T>["modifiers"];
  plugins?: SortableInput<T>["plugins"];
  accept?: SortableInput<T>["accept"];
  type?: SortableInput<T>["type"];
  collisionDetector?: SortableInput<T>["collisionDetector"];
  collisionPriority?: SortableInput<T>["collisionPriority"];
  transition?: SortableInput<T>["transition"];
  // Declaring body content type tells Marko's static analysis that
  // this tag passes one body parameter of type SortableMethods.
  content?: Marko.Body<[SortableMethods]>;
}

static const withoutOptimistic = (defaults: Plugins) =>
  defaults.filter((p) => p !== OptimisticSortingPlugin);

<let-global/manager from="__dndKit_manager"/>
<let/entity=(undefined as Sortable | undefined)/>

static const _makeBox = () => ({
  el: undefined as HTMLElement | undefined,
  handle: undefined as HTMLElement | undefined,
  source: undefined as HTMLElement | undefined,
  target: undefined as HTMLElement | undefined,
});
<let/_pending=_makeBox()/>

<lifecycle
  onMount() {
    if (manager && !this.initialized) this._initEntity();
  }
  onUpdate() {
    if (manager && !this.initialized) this._initEntity();
    if (entity) {
      const e = entity;
      e.id = input.id;
      e.disabled = input.disabled ?? false;
      if (input.data !== undefined) e.data = input.data;
      batch(() => {
        e.group = input.group;
        e.index = input.index;
      });
      e.transition = { ...defaultSortableTransition, ...input.transition };
      if (e.manager?.dragOperation.status.idle && e.transition?.idle) {
        e.refreshShape();
      }
    }
  }
  _initEntity() {
    if (!manager) return;
    const mgr = manager as DragDropManager;
    const e = new Sortable(
      {
        id: input.id,
        index: input.index,
        group: input.group,
        data: input.data,
        disabled: input.disabled ?? false,
        sensors: input.sensors,
        modifiers: input.modifiers,
        plugins: input.plugins ?? withoutOptimistic,
        accept: input.accept,
        type: input.type,
        collisionDetector: input.collisionDetector,
        collisionPriority: input.collisionPriority,
        transition: { ...defaultSortableTransition, ...input.transition },
        register: false,
      },
      mgr,
    );
    this.cleanup = e.register();
    this.initialized = true;
    if (_pending.el !== undefined) { e.element = _pending.el; _pending.el = undefined; }
    if (_pending.handle !== undefined) { e.handle = _pending.handle; _pending.handle = undefined; }
    if (_pending.source !== undefined) { e.source = _pending.source; _pending.source = undefined; }
    if (_pending.target !== undefined) { e.target = _pending.target; _pending.target = undefined; }
    entity = e;
  }
  onDestroy() {
    if (typeof this.cleanup === "function") this.cleanup();
    entity?.destroy();
  }
/>

<create-deep-signal/tracked target=entity/>

// Eagerly read reactive booleans so Marko tracks them as dependencies.
// When tracked changes, these update and _s is rebuilt, re-rendering the body.
<const/_isDragging=(tracked as any)?.isDragging ?? false/>
<const/_isDropping=(tracked as any)?.isDropping ?? false/>
<const/_isDragSource=(tracked as any)?.isDragSource ?? false/>
<const/_isDropTarget=(tracked as any)?.isDropTarget ?? false/>

// Arrow functions for setters — stable closures over $scope so they always
// see the current entity / _pending without needing to be recreated.
<const/_setElement=(el: HTMLElement | undefined) => {
  if (entity) {
    const e = entity;
    if (!el && e.element?.isConnected && !e.manager?.dragOperation.status.idle) return;
    e.element = el;
  } else if (el) { _pending.el = el; }
}/>
<const/_setHandle=(el: HTMLElement | undefined) => {
  if (entity) { const e = entity; e.handle = el; } else if (el) { _pending.handle = el; }
}/>
<const/_setSource=(el: HTMLElement | undefined) => {
  if (entity) {
    const e = entity;
    if (!el && e.source?.isConnected && !e.manager?.dragOperation.status.idle) return;
    e.source = el;
  } else if (el) { _pending.source = el; }
}/>
<const/_setTarget=(el: HTMLElement | undefined) => {
  if (entity) {
    const e = entity;
    if (!el && e.target?.isConnected && !e.manager?.dragOperation.status.idle) return;
    e.target = el;
  } else if (el) { _pending.target = el; }
}/>

// Build the body param object from stable + reactive parts.
// Named <const/_s> so <${input.content}(_s)/> is a simple one-arg call
// that Marko's static analysis can unambiguously detect.
<const/_s=({
  isDragging: _isDragging,
  isDropping: _isDropping,
  isDragSource: _isDragSource,
  isDropTarget: _isDropTarget,
  setElement: _setElement,
  setHandle: _setHandle,
  setSource: _setSource,
  setTarget: _setTarget,
} as SortableMethods)/>

<${input.content}(_s)/>
