import {
  DragDropManager,
  defaultPreset,
  resolveCustomizable,
} from "@dnd-kit/dom";
import type { DragDropManagerInput } from "@dnd-kit/dom";
import type {
  DragDropEventHandlers,
  Draggable,
  Droppable,
} from "@dnd-kit/abstract";
import { createRenderer } from "../../src/runtime/renderer.js";

export interface Input extends DragDropManagerInput {
  manager?: DragDropManager<any, any, any>;
  content?: Marko.Body;
  onBeforeDragStart?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["beforedragstart"];
  onDragStart?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["dragstart"];
  onDragMove?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["dragmove"];
  onDragOver?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["dragover"];
  onDragEnd?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["dragend"];
  onCollision?: DragDropEventHandlers<Draggable, Droppable, DragDropManager>["collision"];
}

<let/manager=(input.manager as DragDropManager<any, any, any>) ??
new DragDropManager({
  plugins: resolveCustomizable(input.plugins, defaultPreset.plugins),
  sensors: resolveCustomizable(input.sensors, defaultPreset.sensors),
  modifiers: resolveCustomizable(input.modifiers, defaultPreset.modifiers),
})>

<let-global/dndManager from="__dndKit_manager"/>

<const/_=(() => { ($global ?? {} as Marko.Global).__dndKit_manager = manager; })()/>

<lifecycle
  onMount() {
    dndManager = manager;

    const m = manager;
    const { renderer, trackRendering } = createRenderer();
    m.renderer = renderer;

    const cleanups = [
      m.monitor.addEventListener("beforedragstart", (event, mgr) =>
        trackRendering(() => input.onBeforeDragStart?.(event, mgr)),
      ),
      m.monitor.addEventListener("dragstart", (event, mgr) =>
        input.onDragStart?.(event, mgr),
      ),
      m.monitor.addEventListener("dragover", (event, mgr) =>
        trackRendering(() => input.onDragOver?.(event, mgr)),
      ),
      m.monitor.addEventListener("dragmove", (event, mgr) =>
        trackRendering(() => input.onDragMove?.(event, mgr)),
      ),
      m.monitor.addEventListener("dragend", (event, mgr) =>
        trackRendering(() => input.onDragEnd?.(event, mgr)),
      ),
      m.monitor.addEventListener("collision", (event, mgr) =>
        input.onCollision?.(event, mgr),
      ),
    ];

    // Store cleanups on this as any — lifecycle-local state, not reactive.
    (this as any).cleanups = cleanups;
  }
  onDestroy() {
    ((this as any).cleanups as Array<() => void>)?.forEach((fn) => fn());
    dndManager = undefined as any;
    if (!input.manager) {
      manager.destroy();
    }
  }
/>

<${input.content}/>
