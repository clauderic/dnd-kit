/*
 * <dnd-context-write> — Internal tag. Do not use directly.
 *
 * Used inside drag-drop-provider.marko to write the DragDropManager onto
 * the provider's branch during the render/input phase (before effects).
 *
 * The translator injects a render statement (not effect) bound to the
 * manager signal's referenced bindings:
 *
 *   scope["#ClosestBranch"]["__dnd_manager"] = manager;
 *
 * This tag is fully removed by the translator (tag.remove() is called).
 * The template body is intentionally empty.
 */
