import { Droppable } from "@dnd-kit/dom";
import type { DroppableInput, DragDropManager } from "@dnd-kit/dom";
import type { Data } from "@dnd-kit/abstract";

export interface DroppableMethods {
  isDropTarget: boolean;
  setElement(el: HTMLElement | undefined): void;
}

export interface Input<T extends Data = Data> {
  id: string | number;
  data?: T;
  disabled?: boolean;
  accept?: DroppableInput<T>["accept"];
  type?: DroppableInput<T>["type"];
  collisionDetector?: DroppableInput<T>["collisionDetector"];
  collisionPriority?: DroppableInput<T>["collisionPriority"];
  content?: Marko.Body<[DroppableMethods]>;
}

<let-global/manager from="__dndKit_manager"/>
<let/entity=undefined as Droppable | undefined>

static const _makeBox = () => ({ el: undefined as HTMLElement | undefined });
<let/_pending=_makeBox()>

<lifecycle
  onMount() {
    if (manager && !(this as any).initialized) (this as any)._initEntity();
  }
  onUpdate() {
    if (manager && !(this as any).initialized) {
      (this as any)._initEntity();
      return;
    }
    if (
      manager &&
      (this as any).initialized &&
      entity &&
      (entity as any).manager !== manager
    ) {
      (this as any).cleanup?.();
      entity.destroy();
      entity = undefined;
      (this as any).initialized = false;
      (this as any)._initEntity();
      return;
    }
    if (entity) {
      const e = entity;
      e.id = input.id;
      e.disabled = input.disabled ?? false;
      if (input.data !== undefined) e.data = input.data;
      if (input.accept !== undefined) e.accept = input.accept;
      if (input.type !== undefined) e.type = input.type;
      // Sync collision config that can change at runtime. Not synced at init
      // because the Droppable constructor applies them. Any update after mount
      // must propagate so collision detection uses current configuration.
      if (input.collisionDetector !== undefined)
        e.collisionDetector = input.collisionDetector;
      if (input.collisionPriority !== undefined)
        e.collisionPriority = input.collisionPriority;
    }
  }
  _initEntity() {
    if (!manager) return;
    const mgr = manager as DragDropManager;
    const e = new Droppable(
      {
        id: input.id,
        data: input.data,
        disabled: input.disabled ?? false,
        accept: input.accept,
        type: input.type,
        collisionDetector: input.collisionDetector,
        collisionPriority: input.collisionPriority,
        register: false,
      },
      mgr,
    );
    (this as any).cleanup = e.register();
    (this as any).initialized = true;
    if (_pending.el !== undefined) {
      e.element = _pending.el;
      _pending.el = undefined;
    }
    entity = e;
  }
  onDestroy() {
    (this as any).cleanup?.();
    entity?.destroy();
  }
>

<create-deep-signal/tracked target=entity/>

<const/_isDropTarget=(
  manager != null && ((tracked as any)?.isDropTarget ?? false)
)>

<const/_d={
  isDropTarget: _isDropTarget,
  setElement: (el: HTMLElement | undefined) => {
    if (entity) {
      const e = entity;
      e.element = el;
    } else if (el) {
      _pending.el = el;
    }
  },
} as DroppableMethods>

<${input.content}(_d)/>
