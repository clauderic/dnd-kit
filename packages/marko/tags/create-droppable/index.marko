/*
 * <create-droppable> — Creates a droppable drop target.
 *
 * Usage:
 *   <create-droppable|droppable| id="zone-1">
 *     <div/$el>
 *       <lifecycle
 *         onMount() { droppable.setElement($el()); }
 *         onDestroy() { droppable.setElement(undefined); }
 *       />
 *       <span class=(droppable.isDropTarget ? 'over' : '')>Drop here</span>
 *     </div>
 *   </create-droppable>
 */

import {Droppable} from '@dnd-kit/dom';
import type {DroppableInput, DragDropManager} from '@dnd-kit/dom';
import type {Data} from '@dnd-kit/abstract';

export interface Input<T extends Data = Data> {
  id: string | number;
  data?: T;
  disabled?: boolean;
  accept?: DroppableInput<T>['accept'];
  type?: DroppableInput<T>['type'];
  collisionDetector?: DroppableInput<T>['collisionDetector'];
  collisionPriority?: DroppableInput<T>['collisionPriority'];
  /** @internal — Set by translator. Do not pass manually. */
  _dndManager?: DragDropManager;
}

<let/entity/>

<lifecycle
  onMount() {
    if (input._dndManager && !this.initialized) {
      this._initEntity();
    }
  }
  onUpdate() {
    if (input._dndManager && !this.initialized) {
      this._initEntity();
    }
    if (entity) {
      entity.id = input.id;
      entity.disabled = input.disabled ?? false;
      if (input.data) entity.data = input.data;
      if (input.accept !== undefined) entity.accept = input.accept;
      if (input.type !== undefined) entity.type = input.type;
    }
  }
  _initEntity() {
    const e = new Droppable(
      {
        id: input.id,
        data: input.data,
        disabled: input.disabled ?? false,
        accept: input.accept,
        type: input.type,
        collisionDetector: input.collisionDetector,
        collisionPriority: input.collisionPriority,
        register: false,
      },
      input._dndManager
    );
    this.cleanup = e.register();
    this.initialized = true;
    entity = e;
  }
  onDestroy() {
    if (typeof this.cleanup === 'function') this.cleanup();
    entity?.destroy();
  }
/>

<create-deep-signal/tracked target=entity/>

<return=({
  get isDropTarget() { return (tracked as any)?.isDropTarget ?? false; },
  setElement(el: HTMLElement | undefined) {
    if (entity) entity.element = el;
  },
})/>

<${input.renderBody}()/>
