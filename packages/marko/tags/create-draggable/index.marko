import { Draggable } from "@dnd-kit/dom";
import type { DraggableInput, DragDropManager } from "@dnd-kit/dom";
import type { Data } from "@dnd-kit/abstract";
import { deepEqual } from "@dnd-kit/state";

export interface DraggableMethods {
  isDragging: boolean;
  isDropping: boolean;
  isDragSource: boolean;
  setElement(el: HTMLElement | undefined): void;
  setHandle(el: HTMLElement | undefined): void;
}

export interface Input<T extends Data = Data> {
  id: string | number;
  data?: T;
  disabled?: boolean;
  sensors?: DraggableInput<T>["sensors"];
  modifiers?: DraggableInput<T>["modifiers"];
  plugins?: DraggableInput<T>["plugins"];
  content?: Marko.Body<[DraggableMethods]>;
}

<let-global/manager from="__dndKit_manager"/>
<let/entity=undefined as Draggable | undefined>

static const _makeBox = () => ({
  el: undefined as HTMLElement | undefined,
  handle: undefined as HTMLElement | undefined,
});
<let/_pending=_makeBox()>

<lifecycle
  onMount() {
    if (manager && !(this as any).initialized) (this as any)._initEntity();
  }
  onUpdate() {
    if (manager && !(this as any).initialized) {
      (this as any)._initEntity();
      return;
    }
    if (
      manager &&
      (this as any).initialized &&
      entity &&
      (entity as any).manager !== manager
    ) {
      (this as any).cleanup?.();
      entity.destroy();
      entity = undefined;
      (this as any).initialized = false;
      (this as any)._initEntity();
      return;
    }
    if (entity) {
      const e = entity;
      const self = this as any;
      e.id = input.id;
      e.disabled = input.disabled ?? false;
      if (input.data !== undefined) e.data = input.data;
      // sensors, modifiers, plugins — DEEP-COMPARED. Marko's onUpdate runs
      // on every re-render, so without this guard these would be reassigned
      // every render when written inline (e.g. `plugins={[MyPlugin]}`). Each
      // reassignment triggers Preact reactive cascades through the entity's
      // signal graph — Feedback in particular can mis-time during drag.
      // Matches React's `useOnValueChange(..., undefined, deepEqual)`.
      if (!deepEqual(input.sensors, self._prevSensors)) {
        e.sensors = input.sensors;
        self._prevSensors = input.sensors;
      }
      if (!deepEqual(input.modifiers, self._prevModifiers)) {
        e.modifiers = input.modifiers;
        self._prevModifiers = input.modifiers;
      }
      if (!deepEqual(input.plugins, self._prevPlugins)) {
        e.plugins = input.plugins;
        self._prevPlugins = input.plugins;
      }
    }
  }
  _initEntity() {
    if (!manager) return;
    const mgr = manager as DragDropManager;
    const e = new Draggable(
      {
        id: input.id,
        data: input.data,
        disabled: input.disabled ?? false,
        sensors: input.sensors,
        modifiers: input.modifiers,
        plugins: input.plugins,
        register: false,
      },
      mgr,
    );
    (this as any).cleanup = e.register();
    (this as any).initialized = true;
    if (_pending.el !== undefined) {
      e.element = _pending.el;
      _pending.el = undefined;
    }
    if (_pending.handle !== undefined) {
      e.handle = _pending.handle;
      _pending.handle = undefined;
    }
    // Seed previous values for the deep-equality-tracked props in onUpdate.
    // Without seeding, the first onUpdate after init would see _prevX ===
    // undefined and sync the initial value a second time — the constructor
    // already applied these. Matches React's `useOnValueChange`, which
    // initializes its `tracked.current` to the initial value so the first
    // effect run sees no change.
    const self = this as any;
    self._prevSensors = input.sensors;
    self._prevModifiers = input.modifiers;
    self._prevPlugins = input.plugins;
    entity = e;
  }
  onDestroy() {
    (this as any).cleanup?.();
    entity?.destroy();
  }
>

<create-deep-signal/tracked target=entity/>

<const/_isDragging=manager != null && ((tracked as any)?.isDragging ?? false)>
<const/_isDropping=manager != null && ((tracked as any)?.isDropping ?? false)>
<const/_isDragSource=(
  manager != null && ((tracked as any)?.isDragSource ?? false)
)>

<const/_d={
  isDragging: _isDragging,
  isDropping: _isDropping,
  isDragSource: _isDragSource,
  setElement: (el: HTMLElement | undefined) => {
    if (entity) {
      const e = entity;
      if (
        !el &&
        e.element?.isConnected &&
        !e.manager?.dragOperation.status.idle
      )
        return;
      e.element = el;
    } else if (el) {
      _pending.el = el;
    }
  },
  setHandle: (el: HTMLElement | undefined) => {
    if (entity) {
      const e = entity;
      e.handle = el;
    } else if (el) {
      _pending.handle = el;
    }
  },
} as DraggableMethods>

<${input.content}(_d)/>
