/*
 * <create-draggable> — Creates a draggable entity.
 *
 * Manager arrives reactively via <let-global>. Entity is created in
 * _initEntity when manager first becomes available. Pending element/handle
 * calls that arrive before entity exists are buffered and applied on init.
 *
 * Local variable pattern: property assignments on <let> variables must go
 * through a local const (e.g. `const e = entity`) to prevent the Marko
 * compiler from emitting invalid `$scope.entity?.prop = value`.
 */

import { Draggable } from "@dnd-kit/dom";
import type { DraggableInput, DragDropManager } from "@dnd-kit/dom";
import type { Data } from "@dnd-kit/abstract";

export interface Input<T extends Data = Data> {
  id: string | number;
  data?: T;
  disabled?: boolean;
  sensors?: DraggableInput<T>["sensors"];
  modifiers?: DraggableInput<T>["modifiers"];
  plugins?: DraggableInput<T>["plugins"];
}

<let-global/manager from="__dndKit_manager"/>

<let/entity=(undefined as Draggable | undefined)/>

static const _makeBox = () => ({
  el: undefined as HTMLElement | undefined,
  handle: undefined as HTMLElement | undefined,
});
<let/_pending=_makeBox()/>

<lifecycle
  onMount() {
    if (manager && !this.initialized) this._initEntity();
  }
  onUpdate() {
    if (manager && !this.initialized) this._initEntity();
    if (entity) {
      // Extract to local: avoids $scope.entity?.prop = value (invalid JS).
      const e = entity;
      e.id = input.id;
      e.disabled = input.disabled ?? false;
      if (input.data !== undefined) e.data = input.data;
    }
  }
  _initEntity() {
    if (!manager) return;
    const e = new Draggable(
      {
        id: input.id,
        data: input.data,
        disabled: input.disabled ?? false,
        sensors: input.sensors,
        modifiers: input.modifiers,
        plugins: input.plugins,
        register: false,
      },
      manager as DragDropManager,
    );
    this.cleanup = e.register();
    this.initialized = true;
    if (_pending.el !== undefined) { e.element = _pending.el; _pending.el = undefined; }
    if (_pending.handle !== undefined) { e.handle = _pending.handle; _pending.handle = undefined; }
    entity = e;
  }
  onDestroy() {
    if (typeof this.cleanup === "function") this.cleanup();
    entity?.destroy();
  }
/>

<create-deep-signal/tracked target=entity/>

<return=({
  get isDragging() { return (tracked as any)?.isDragging ?? false; },
  get isDropping() { return (tracked as any)?.isDropping ?? false; },
  get isDragSource() { return (tracked as any)?.isDragSource ?? false; },
  setElement(el: HTMLElement | undefined) {
    if (entity) {
      const e = entity;
      if (!el && e.element?.isConnected && !e.manager?.dragOperation.status.idle) return;
      e.element = el;
    } else if (el) {
      _pending.el = el;
    }
  },
  setHandle(el: HTMLElement | undefined) {
    if (entity) {
      const e = entity;
      e.handle = el;
    } else if (el) {
      _pending.handle = el;
    }
  },
})/>

<${input.renderBody}()/>
